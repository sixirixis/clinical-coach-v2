NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
FRONTEND_ORIGIN=http://localhost:5173
VAPI_PRIVATE_KEY=your_rotated_vapi_private_key_here
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here
VAPI_WEBHOOK_BEARER_TOKEN=your_vapi_webhook_bearer_token_here
DATABASE_URL=postgresql://username:password@localhost:5432/coach_app
JWT_SECRET=replace_with_a_long_random_secret
SESSION_ENCRYPTION_KEY=replace_with_a_different_long_random_secret
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
REVIEW_MODEL=gpt-4.1-mini
STORE_TRANSCRIPTS=true
STORE_AUDIO=false
ENABLE_LLM_REVIEW=true
DEFAULT_TIMEZONE=UTC
